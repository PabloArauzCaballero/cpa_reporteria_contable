# API real obligatoria. Este frontend no incluye datos locales ni modo de datos locales.
VITE_API_BASE_URL=http://localhost:3000

# Login real. La petición de login NO envía X-Session-Token para evitar 401 por tokens viejos.
VITE_AUTH_LOGIN_ENDPOINT=/api/auth/publicAuth/login

# Endpoint único especializado. Debe leer desde contabilidad.v_powerbi_contable_movimiento.
VITE_REPORTERIA_CONTABLE_ENDPOINT=/api/reporteria/contabilidad/powerbi-movimientos
